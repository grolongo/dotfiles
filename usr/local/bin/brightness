#!/usr/bin/env bash
set -e
set -u
set -o pipefail
IFS=$'\n\t'

get_brightness() {
    brightness_current=$(brightnessctl get)
    brightness_max=$(brightnessctl max)
    awk -v current="${brightness_current}" -v max="${brightness_max}" 'BEGIN { printf "%.0f", current/max*100 }'
}

show_brightness_notif() {
    brightness=$(get_brightness)
    notify-send -u low -i /usr/share/icons/Adwaita/symbolic/status/display-brightness-symbolic.svg -h string:x-dunst-stack-tag:brightness_notif -h int:value:"${brightness}" "Brightness: ${brightness}%"
}

main() {
    case "${1}" in
        up)
            brightnessctl -q set +10%
            show_brightness_notif
            ;;
        down)
            brightnessctl -q set 10%-
            show_brightness_notif
            ;;
    esac
}

main "${1}"
