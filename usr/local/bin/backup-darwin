#!/usr/bin/env bash
set -e
set -u
set -o pipefail
IFS=$'\n\t'

tmpdir=$(mktemp -d)
trap 'rm -rf "${tmpdir}"' EXIT
tarfile="${tmpdir}/backup.tar.gz"

os_check() {
    if [[ "$(uname)" != Darwin ]]; then
        printf '\033[31mNot running macOS, exiting.\033[0m\n' >&2
        exit 1
    fi
}

compress_backup() {
    read -r -e -p "Enter sync folder path: " syncpath

    printf 'Creating tar file...\n'
    tar --create --gunzip --file "${tarfile}" \
        --exclude="Music" \
        --exclude=".seafile-data" \
        --exclude="seafile-data" \
        --exclude="vz" \
        --exclude="Desktop.ini" \
        --exclude=".git" \
        --exclude=".DS_Store" \
        --exclude=".SynologyWorkingDirectory" \
        -C "$syncpath" . \
        -C "$HOME" dotfiles
}

veracrypt_backup() {
    local veracrypt_path container_path volume_path
    veracrypt_path=/Applications/VeraCrypt.app/Contents/MacOS/VeraCrypt
    container_path="$HOME/Desktop/backup.hc"
    volume_path=/Volumes/backup

    # Calculating the size of the container.
    zip_size_raw=$(du -m "$tarfile" | cut -f1)
    zip_size=$(( $zip_size_raw + 5 ))

    printf 'Creating container...\n'
    "${veracrypt_path}" --text \
                        --create \
                        --encryption=aes-twofish-serpent \
                        --hash=whirlpool \
                        --random-source=/dev/urandom \
                        --size="${zip_size}M" \
                        --volume-type=normal \
                        --filesystem=FAT \
                        --pim=0 \
                        --protect-hidden=no \
                        --keyfiles="" \
                        --no-size-check \
                        "$container_path"

    printf 'Mounting container...\n'
    "${veracrypt_path}" --text \
                        --hash=whirlpool \
                        --protect-hidden=no \
                        --keyfiles="" \
                        --pim=0 \
                        "$container_path" \
                        "$volume_path"

    printf 'Copying backup zipfile...\n'
    cp -r "${tarfile}" "${volume_path}"

    printf 'Unmounting all VeraCrypt volumes...\n'
    "${veracrypt_path}" -d

    sync

    printf 'Backup container saved at %s' "${container_path}"
}

gnupg_backup() {
    local gpg_backup
    gpg_backup="$HOME/backup.tar.gz.gpg"

    printf 'Encrypting tar file...'
    gpg --s2k-mode 3 \
        --s2k-cipher-algo AES256 \
        --s2k-digest-algo SHA512 \
        --s2k-count 65000000 \
        --pinentry-mode=ask \
        --output "${gpg_backup}" \
        --symmetric "${tarfile}"

    printf 'Backup file saved at %s' "${gpg_backup}"
}

usage() {
    printf '\n'
    printf 'Usage:'
    printf '  veracrypt'
    printf '  gnupg'
    printf '\n'
}

main() {
    os_check

    if [[ -z "${1}" ]]; then
        usage
        exit 1
    fi

    if [[ "${1}" == "veracrypt" ]]; then
        compress_backup
        veracrypt_backup
    elif [[ "${1}" == "gnupg" ]]; then
        compress_backup
        gnupg_backup
    else
        usage
    fi
}

main "$@"
