        waybar
        wireplumber
        wl-clipboard
        xdg-desktop-portal
        xdg-desktop-portal-wlr
        xwayland
        yaru-theme-gtk
        yaru-theme-icon
    )

    for p in "${packages[@]}"; do
        if confirm "Install ${p}?" "Y"; then
            apt install -y "${p}"
        fi
    done

    if confirm "Install Firefox (SNAP)?" "Y"; then
        snap install firefox
    fi

    snap refresh

    if confirm "Install autotiling script for sway?" "Y"; then
        apt install python3-i3ipc
        wget -O /usr/local/bin/autotiling \
             https://raw.githubusercontent.com/nwg-piotr/autotiling/refs/heads/master/autotiling/main.py
        chmod +x /usr/local/bin/autotiling
    fi

    usermod -aG video "${SUDO_USER}"
    timedatectl set-timezone Europe/Paris

    local nerdfonts_latest repo release
    nerdfonts_latest=$(wget -qO- "https://api.github.com/repos/ryanoasis/nerd-fonts/releases/latest" | jq --raw-output .tag_name)
    nerdfonts_latest=${nerdfonts_latest#v}
    repo="https://github.com/ryanoasis/nerd-fonts/releases/download/"
    release="v${nerdfonts_latest}/NerdFontsSymbolsOnly.zip"

    (
        cd "${tmpdir}" || exit 1
        wget "${repo}${release}"
        unzip NerdFontsSymbolsOnly.zip -d /usr/share/fonts/opentype/nerdfonts
    )

    (
        cd "${tmpdir}" || exit 1
        wget https://use.fontawesome.com/releases/v7.1.0/fontawesome-free-7.1.0-desktop.zip
        unzip fontawesome-free-7.1.0-desktop.zip
        mkdir -vp /usr/share/fonts/opentype/font-awesome-7
        mv ./fontawesome-free-7.1.0-desktop/otfs/*.otf /usr/share/fonts/opentype/font-awesome-7
    )

    fc-cache -f -v
}

set_git() {
    (
        cd "${HOME}/dotfiles"
        if [ "$(git rev-parse --is-inside-work-tree)" ]; then
            git remote set-url origin git@github.com:grolongo/dotfiles.git
        else
            git init
            git remote add origin git@github.com:grolongo/dotfiles.git
            git fetch
            git reset origin/master
            git branch --set-upstream-to=origin/master
        fi
    )
}

usage() {
    printf '\n'
    printf 'Usage:\n'
    printf 'isetup      (s) - passwordless sudo and lock root\n'
    printf 'aptcommon   (s) - install packages from official Ubuntu repositories\n'
    printf 'aptextra    (s) - install packages from third party sources and repositories\n'
    printf 'snaps       (s) - install a few snaps\n'
    printf 'emacs       (s) - build Emacs from latest stable\n'
    printf 'gsettings       - configures Gnome settings\n'
    printf 'i3          (s) - install and set up i3wm related packages & configs\n'
    printf 'sway        (s) - install and set up sway related packages & configs\n'
    printf 'git             - set correct SSH origin for this repository\n'
    printf '\n'
}

main() {
    os_check

    if [ -z "${1-}" ]; then
        usage
        exit 1
    fi

    if [ "${1}" = "isetup" ]; then
        check_is_sudo
        initial_setup
    elif [ "${1}" = "aptcommon" ]; then
        check_is_sudo
        apt_common
        apt_clean
    elif [ "${1}" = "aptextra" ]; then
        check_is_sudo
        apt_extra
        apt_clean
    elif [ "${1}" = "snaps" ]; then
        check_is_sudo
        snaps_common
    elif [ "${1}" = "emacs" ]; then
        check_is_sudo
        build_emacs
    elif [ "${1}" = "gsettings" ]; then
        check_is_not_sudo
        set_gsettings
    elif [ "${1}" = "i3" ]; then
        check_is_sudo
        set_i3wm
        apt_clean
    elif [ "${1}" = "sway" ]; then
        check_is_sudo
        jq_check
        set_sway
        apt_clean
    elif [ "${1}" = "git" ]; then
        check_is_not_sudo
        set_git
    else
        usage
    fi
}

main "$@"
