#!/usr/bin/env bash
set -e
set -u
set -o pipefail
IFS=$'\n\t'

arch=$(dpkg --print-architecture)
distrib=$(lsb_release -sc 2> /dev/null)
tmpdir=$(mktemp -d); trap 'rm -rf "$tmpdir"' EXIT

msg_info() {
    printf '\n'
    printf '\033[34m%s\033[0m\n' "$1"
}

msg_error() {
    printf '\033[31m%s\033[0m\n' "$1" >&2
}

check_is_sudo() {
    [ "$(id -u)" -eq 0 ] || { msg_error "Requires root privileges. Use sudo."; exit 1; }
}

check_is_not_sudo() {
    [ "$(id -u)" -ne 0 ] || { msg_error "Don't run this as sudo."; exit 1; }
}

confirm() {
    local prompt default response
    prompt="$1"
    default="$2"

    case "$default" in
        Y) prompt="$prompt [Y/n]";;
        N) prompt="$prompt [y/N]";;
        *) prompt="$prompt [y/n]";;
    esac

    while true; do
        read -r -p "$prompt: " response
        response=${response:-$default}

        case "$response" in
            [Yy]|[Yy][Ee][Ss]) return 0;;
            [Nn]|[Nn][Oo]) return 1;;
            *) printf "Please answer yes or no.\n";;
        esac
    done
}

apt_clean() {
    msg_info "Cleaning up..."
    apt autoremove
    apt autoclean
    apt clean
}

spin() {
    sp='/-\|'
    printf ' '
    while sleep 0.1; do
        printf '\b%.1s' "$sp"
        sp=${sp#?}${sp%???}
    done
}

os_check() {
    # sourcing /etc/os-release file which contains $ID variable
    if [ -f /etc/os-release ]; then
        source /etc/os-release
    else
        msg_error "Not running Ubuntu, exiting."
        exit 1
    fi

    [ "$ID" = ubuntu ] || { msg_error "Not running Ubuntu, exiting."; exit 1; }
}

jq_check() {
    command -v jq >/dev/null 2>&1 || { apt install jq; sleep 5; }
}

initial_setup() {
    if confirm "Enable passwordless sudo for ${SUDO_USER}?" "Y"; then
        printf '%s\n' "${SUDO_USER} ALL=(ALL:ALL) NOPASSWD: ALL" > /etc/sudoers.d/"${SUDO_USER}"
        printf '\n'
    fi

    if confirm "Disable ROOT account for security?" "Y"; then
        passwd --delete root
        passwd --lock root
    fi

    if confirm "Enable architecture variant for apt packages?" "Y"; then
        apt update
        apt install -y dpkg
        mapfile -t results < <(ld.so --help | grep 'supported' | sed 's/^[[:space:]]*//; s/[[:space:]]*$//')

        if [ ${#results[@]} -eq 0 ]; then
            msg_error "No supported versions available."
            exit 1
        fi

        PS3="Please select a version (enter number): "

        select choice in "${results[@]}"; do
            if [ -z "${choice}" ]; then
                msg_error "Invalid choice. Try again."
                continue
            fi

            case "${choice}" in
                *v2*)
                    version_number=v2
                    break;;
                *v3*)
                    version_number=v3
                    break;;
                *v4*)
                    version_number=v4
                    break;;
                *)
                    msg_error "Couldn't find a matching version. Aborting."
                    break;;
            esac
        done

        [ -z "${version_number+x}" ] &&
            printf '%s\n' "APT::Architecture-Variants \"amd64${version_number}\";" \
                   > /etc/apt/apt.conf.d/99enable-amd64"${version_number}"

        apt update
        apt upgrade
    fi

    msg_info "Creating Downloads folder in home..."
    mkdir -vp "/home/${SUDO_USER}/Downloads"
    chown "${SUDO_USER}":"${SUDO_USER}" "/home/${SUDO_USER}/Downloads"
}

