#!/usr/bin/env bash
set -e
set -u
set -o pipefail
IFS=$'\n\t'

usage() {
    printf "Usage: extract <path/file_name>.<zip|rar|bz2|gz|tar|tbz2|tgz|7z|xz|exe|tar.bz2|tar.gz|tar.xz|tar.zst|lzma|pax.Z|Z|dmg|pax|deb|rpm>\n"
}

filecheck() {
    if [ -z "${1}" ]; then
        usage
        exit 1
    fi

    if [ ! -f "${1}" ]; then
        printf "%s - file does not exist\n" "${1}"
        exit 1
    fi
}

main() {
    filenameToLowerCase="${1,,}"
    case "${filenameToLowerCase}" in
        *.tar)            tar xvf "${1}"                                        ;;
        *.tar.bz2|*.tbz2) tar xvjf "${1}"                                       ;;
        *.tar.gz|*.tgz)   tar xvzf "${1}"                                       ;;
        *.tar.xz)         tar xvJf "${1}"                                       ;;
        *.tar.zst)        tar --zstd -xvf "${1}"                                ;;
        *.lzma)           unlzma "${1}"                                         ;;
        *.bz2)            bunzip2 "${1}"                                        ;;
        *.rar)            unrar x -ad "${1}"                                    ;;
        *.gz)             gunzip "${1}"                                         ;;
        *.zip)            unzip "${1}"                                          ;;
        *.pax.Z)          uncompress "${1}" --stdout | pax-r                    ;;
        *.Z)              uncompress "${1}"                                     ;;
        *.7z)             7z x "${1}"                                           ;;
        *.xz)             unxz "${1}"                                           ;;
        *.exe)            cabextract "${1}"                                     ;;
        *.dmg)            hdiutil mount "${1}"                                  ;;
        *.pax)            cat "${1}" | pax-r                                    ;;
        *.deb)            ar x "${1}"                                           ;;
        *.rpm)            rpm2cpio "${1}" | cpio -idmv                          ;;
        *)                printf "extract: %s - unknown archive method\n" "${1}";;
    esac
}

filecheck "${1-}"
main "${1}"
