#!/usr/bin/env bash
set -e
set -u
set -o pipefail
IFS=$'\n\t'

os_check() {
    if [[ "$OSTYPE" != linux* ]]; then
        printf '\033[31mYou are not running Linux. Exiting.\033[0m\n' >&2
        exit 1
    fi
}

compress_backup() {
    read -r -e -p "Enter sync folder path: " syncpath

    tmpdir=$(mktemp -d)
    trap 'rm -rf "$tmpdir"' EXIT
    tarfile="$tmpdir/backup.tar.gz"

    printf 'Creating tar file...\n'
    tar --create --gunzip --file "$tarfile" \
        --exclude="Music" \
        --exclude=".seafile-data" \
        --exclude="seafile-data" \
        --exclude="vz" \
        --exclude="Desktop.ini" \
        --exclude=".git" \
        --exclude=".DS_Store" \
        --exclude=".SynologyWorkingDirectory" \
        -C "$syncpath" . \
        -C "$HOME" dotfiles
}

cryptsetup_backup() {
    backup_container="$HOME/backup.luks"
    mnt_folder=/mnt/luksvol
    vol_name=backup

    printf 'Creating container at %s\n' "${backup_container}"
    fallocate -l 500M "$backup_container"

    sleep 5

    printf 'Encrypting file...'
    sudo cryptsetup -v --type LUKS \
         --cipher aes-xts-plain64 \
         --key-size 512 \
         --hash sha512 \
         luksFormat "$backup_container"

    sleep 5

    printf 'Making the filesystem...'
    sudo cryptsetup luksOpen "$backup_container" "$vol_name"
    mkfs.vfat -F 32 "/dev/mapper/$vol_name"

    sleep 5

    printf 'Mounting the device...\n'
    mkdir -vp "$mnt_folder"
    mount /dev/mapper/"$vol_name" "$mnt_folder"

    sleep 5

    printf 'Copying files...\n'
    cp -v "$HOME"/Downloads/fooc.txt "$mnt_folder"

    sleep 5

    printf 'Closing container...\n'
    umount "$mnt_folder"
    sudo cryptsetup luksClose "$vol_name"
    rm -rf "$mnt_folder"
}

gnupg_backup() {
    gpg_backup="$HOME/backup.tar.gz.gpg"

    printf 'Encrypting tar file...\n'
    gpg --s2k-mode 3 \
        --s2k-cipher-algo AES256 \
        --s2k-digest-algo SHA512 \
        --s2k-count 65000000 \
        --pinentry-mode=ask \
        --output "$gpg_backup" \
        --symmetric "$tarfile"

    printf 'Deleting temp folder...\n'
    rm -rf "$tmpdir"

    printf 'Backup file saved at %s\n' "${gpg_backup}"
}

usage() {
    printf '\n'
    printf 'Usage:'
    printf '  VeraCrypt'
    printf '  GnuPG'
    printf '\n'
}

main() {
    os_check

    if [[ -z "${1-}" ]]; then
        usage
        exit 1
    fi

    if [[ "${1}" == "cryptsetup" ]]; then
        cryptsetup_backup
    elif [[ "${1}" == "gnupg" ]]; then
        compress_backup
        gnupg_backup
    else
        usage
    fi
}

main "$@"
