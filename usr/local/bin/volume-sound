#!/usr/bin/env bash
set -e
set -u
set -o pipefail
IFS=$'\n\t'

volume_check() {
    local text

    if [[ "${1}" == "low" ]]; then
        amixer -q set Master 5%- unmute
        text=$(amixer sget Master | tail -1 | cut -d' ' -f6 | sed 's/\(\[\|\]\)//g')
    elif [[ "${1}" == "high" ]]; then
        amixer -q set Master 5%+ unmute
        text=$(amixer sget Master | tail -1 | cut -d' ' -f6 | sed 's/\(\[\|\]\)//g')
    elif [[ "${1}" == "mute" ]]; then
        amixer -q set Master toggle
        text=$(amixer sget Master | tail -1 | cut -d' ' -f8 | sed 's/\(\[\|\]\)//g')
    else
        printf "Usage volume [low | high | mute]\n"
    fi
}

notification() {
    local id
    id=$(cat "${HOME}"/.config/dunst/.dunst_volume)
    if (( id > 0 )); then
        notify-send -p -r "${id}" "Volume: ${text}" > "${HOME}"/.config/dunst/.dunst_volume
    else
        notify-send -p "Volume: ${text}" > "${HOME}"/.config/dunst/.dunst_volume
    fi
}

main() {
    volume_check "${1}"
    notification
}

main "$@"
