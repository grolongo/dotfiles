#!/usr/bin/env bash
set -e
set -u
set -o pipefail
IFS=$'\n\t'

source=${BASH_SOURCE[0]}

while [[ -L "${source}" ]]; do
    dir=$(cd -P "$(dirname "${source}")" && pwd)
    source=$(readlink "${source}")
    [[ "${source}" != /* ]] && source="$dir/$source"
done

dir=$(cd -P "$(dirname "$source")" && pwd)
base="${dir%/*/*/*}"

confirm() {
    local prompt default response
    prompt="$1"
    default="$2"

    case "$default" in
        Y) prompt="$prompt [Y/n]";;
        N) prompt="$prompt [y/N]";;
        *) prompt="$prompt [y/n]";;
    esac

    while true; do
        read -r -p "$prompt: " response
        response=${response:-$default}

        case "$response" in
            [Yy]|[Yy][Ee][Ss]) return 0;;
            [Nn]|[Nn][Oo]) return 1;;
            *) printf "Please answer yes or no.\n";;
        esac
    done
}

symlink() {
    local sourcefile targetlink
    sourcefile="${base}"/"$1"
    targetlink="${HOME}"/"$1"

    if [[ -e "$sourcefile" ]]; then
        ln -snfv "$sourcefile" "$targetlink"
    else
        printf '%s does not exist.\n' "$sourcefile" >&2
    fi
}

symlink_root() {
    local sourcefile targetlink
    sourcefile="${base}"/"$1"
    targetlink=/"$1"

    if [[ -e "$sourcefile" ]]; then
        sudo ln -snfv "$sourcefile" "$targetlink"
    else
        printf '%s does not exist.\n' "$sourcefile" >&2
    fi
}

user_check() {
    if confirm "Install symlinks for ${USER}?" "Y"; then
        return 0
    else
        exit 1
    fi
}

symlink_zsh() {
    if confirm "link Zsh files?" "Y"; then
        mkdir -vp "${HOME}/.cache/zsh"
        symlink ".zshrc"
        symlink ".zshenv"
        symlink ".aliases"
        symlink ".exports"
        #symlink ".zlogin" # for i3
    fi
}

symlink_bash() {
    if confirm "link Bash files?" "Y"; then
        mkdir -vp "${HOME}/.cache/bash"
        symlink ".bashrc"
        symlink ".inputrc"
        symlink ".aliases"
        symlink ".exports"
    fi
}

symlink_emacs() {
    if  confirm "link Emacs config?" "Y"; then
        mkdir -vp "${HOME}/.config/emacs"
        symlink ".config/emacs/init.el"
        symlink ".config/emacs/early-init.el"
    fi
}

symlink_chatty() {
    if confirm "link Chatty files?" "Y"; then
        mkdir -vp "${HOME}/.chatty"
        symlink ".chatty/settings"
    fi
}

symlink_mpv() {
    if confirm "link mpv files?" "Y"; then
        mkdir -vp "${HOME}/.config/mpv"
        mkdir -vp "${HOME}/.config/mpv/scripts"
        symlink ".config/mpv/input.conf"
        symlink ".config/mpv/mpv.conf"
        symlink ".config/mpv/scripts/osctoggle.lua"
        symlink ".config/mpv/script-opts"
    fi
}

symlink_tmux() {
    if confirm "link tmux config file?" "Y"; then
        mkdir -vp "${HOME}/.config/tmux"
        symlink ".config/tmux/tmux.conf"
    fi
}

symlink_rtorrent() {
    if confirm "link rtorrent config file?" "Y"; then
        mkdir -vp "${HOME}/Downloads"
        mkdir -vp "${HOME}/.cache/rtorrent"
        symlink ".config/rtorrent/rtorrent.rc"
    fi
}

symlink_aria() {
    if confirm "link aria2 config file?" "Y"; then
        mkdir -vp "${HOME}/.config/aria2"
        symlink ".config/aria2/aria2.conf"
    fi
}

symlink_vim() {
    if confirm "link vim file?" "Y"; then
        mkdir -vp "${HOME}/.vim"
        symlink ".vimrc"
    fi
}

symlink_mg() {
    if confirm "link mg file?" "Y"; then
        symlink ".mg"
    fi
}

symlink_git() {
    if confirm "link gitconfig file?" "Y"; then
        mkdir -vp "${HOME}/.config/git"
        symlink ".config/git/config"
    fi
}

symlink_streamlink() {
    if confirm "link Streamlink config file?" "Y"; then
        if [[ "$(uname)" = Darwin ]]; then
            ln -snfv "${base}/.config/streamlink/config" \
               "${HOME}/Library/Application Support/streamlink/config"
        else
            mkdir -vp "${HOME}/.config/streamlink"
            symlink ".config/streamlink/config"
        fi
    fi
}

symlink_i3() {
    if confirm "link i3wm files?" "Y"; then
        mkdir -vp "${HOME}/.config/i3"
        symlink ".config/i3/config"
        mkdir -vp "${HOME}/.config/i3status"
        symlink ".config/i3status/config"
        mkdir -vp "${HOME}/.config/dunst"
        symlink ".config/dunst/dunstrc"
        symlink ".xsessionrc"
        mkdir -vp "${HOME}/.config/fontconfig"
        symlink ".config/fontconfig/fonts.conf"
        sudo mkdir -vp /etc/X11/xorg.conf.d
        symlink_root "etc/X11/xorg.conf.d/30-touchpad.conf"
        symlink_root "etc/X11/xorg.conf.d/30-trackpoint.conf"
        symlink ".config/mimeapps.list"
    fi
}

symlink_sway() {
    if confirm "link SwayWM files?" "Y"; then
        mkdir -vp "${HOME}/.config/sway"
        symlink ".config/sway/config"
        mkdir -vp "${HOME}/.config/swaylock"
        symlink ".config/swaylock/config"
        mkdir -vp "${HOME}/.config/swayimg"
        symlink ".config/swayimg/config"
        mkdir -vp "${HOME}/.config/i3status"
        symlink ".config/i3status/config"
        mkdir -vp "${HOME}/.config/fontconfig"
        symlink ".config/fontconfig/fonts.conf"
        mkdir -vp "${HOME}/.config/foot"
        symlink ".config/foot/foot.ini"
        mkdir -vp "${HOME}/.config/tofi"
        symlink ".config/tofi/config"
        mkdir -vp "${HOME}/.config/mako"
        symlink ".config/mako/config"
        mkdir -vp "${HOME}/.config/waybar"
        symlink ".config/waybar/config.jsonc"
        symlink ".config/waybar/style.css"
        symlink ".config/mimeapps.list"
    fi
}

symlink_x11() {
    if confirm "link Xresources config file?" "Y"; then
        symlink ".Xresources"
    fi
}

symlink_tlp() {
    if confirm "link TLP config file?" "Y"; then
        sudo mkdir -vp /etc/tlp.d
        symlink_root "etc/tlp.d/01-t480s-i5-8250u.conf"
    fi
}

symlink_systemd() {
    if confirm "link systemd unit files?" "Y"; then
        mkdir -vp "${HOME}/.config/systemd/user"
        symlink ".config/systemd/user/battery.timer"
        symlink ".config/systemd/user/battery.service"
        systemctl --user enable battery.timer
    fi
}

symlink_binary() {
    if confirm "link binary files?" "Y"; then
        symlink_root "usr/local/bin/extract"
        symlink_root "usr/local/bin/url"
        sudo ln -snfv "${base}/usr/local/bin/symlink-unix" "/usr/local/bin/symlink"
        if [[ "$(uname)" = Darwin ]]; then
            symlink_root "usr/local/bin/install-darwin"
            sudo ln -snfv "${base}/usr/local/bin/backup-darwin" \
                 "/usr/local/bin/backup"
            sudo ln -snfv "${base}/usr/local/sbin/usb-format-darwin" \
                 "/usr/local/sbin/usb-format"
        else
            symlink_root "usr/local/bin/install-ubuntu"
            sudo ln -snfv "${base}/usr/local/bin/backup-linux" \
                 "/usr/local/bin/backup"
            sudo ln -snfv "${base}/usr/local/sbin/usb-format-linux" \
                 "/usr/local/sbin/usb-format"
            symlink_root "usr/local/bin/battery"
            symlink_root "usr/local/bin/brightness"
            symlink_root "usr/local/bin/colorpicker"
            symlink_root "usr/local/bin/swaylock-randomize"
            symlink_root "usr/local/bin/volume-sound"
            symlink_root "usr/local/sbin/keyboard-backlight"
            symlink_root "usr/local/sbin/password-store-cryptsetup"
            symlink_root "usr/local/sbin/wifi-scan"
        fi
    fi
}

main() {
    user_check
    symlink_zsh
    symlink_bash
    # symlink_emacs
    symlink_chatty
    symlink_mpv
    symlink_tmux
    symlink_rtorrent
    symlink_aria
    symlink_vim
    symlink_mg
    symlink_git
    symlink_streamlink
    symlink_i3
    symlink_sway
    symlink_x11
    symlink_tlp
    symlink_systemd
    symlink_binary
}

main
